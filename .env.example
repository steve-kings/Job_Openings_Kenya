# Public Supabase connection
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Explicit allowlist of crawler sources. Keep this JSON on one line in Vercel.
# kind=annex consumes the Annex API; kind=jsonld crawls JobPosting JSON-LD from approved websites.
JOB_SCRAPER_SOURCES_JSON=[{"name":"annex","kind":"annex","maxPages":3,"autoPublish":false,"enabled":true}]
