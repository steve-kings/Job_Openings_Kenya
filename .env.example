# Public Supabase connection
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Explicit allowlist of crawler sources. Keep this JSON on one line in Vercel.
# kind=annex consumes the Annex API; kind=jsonld crawls JobPosting JSON-LD from approved websites.
# Annex sources default to location=Kenya, a 90-day age limit, and substantive descriptions.
JOB_SCRAPER_SOURCES_JSON=[{"name":"annex","kind":"annex","location":"Kenya","maxPages":3,"maxAgeDays":90,"minimumDescriptionLength":160,"autoPublish":false,"enabled":true}]
